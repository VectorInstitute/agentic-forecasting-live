{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VectorInstitute/agentic-forecasting-live/main/monitor/schemas/leaderboard.schema.json",
  "title": "Leaderboard aggregate",
  "description": "Small, site-facing aggregate the monitor fetches for the overview. Derived by the harness from resolution records; the log remains the source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "generated_at", "horizons", "cells", "cumulative"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_by": {
      "type": "string",
      "enum": ["mock", "harness"],
      "description": "Provenance flag. 'mock' triggers the site's MOCK DATA banner."
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "horizons": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 1
    },
    "cells": {
      "type": "array",
      "description": "One row per (method, model, horizon) with its mean CRPS, sample size, coverage, and freshness.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "model", "horizon", "mean_crps", "n", "last_updated"],
        "properties": {
          "method": { "type": "string" },
          "model": { "type": ["string", "null"] },
          "horizon": { "type": "integer", "minimum": 1 },
          "mean_crps": { "type": "number", "minimum": 0 },
          "n": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of resolved origins contributing to this cell."
          },
          "coverage_90": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "description": "Empirical coverage of the nominal-90% (0.05-0.95) interval."
          },
          "skill_vs_naive": {
            "type": ["number", "null"],
            "description": "Optional CRPS skill score relative to the naive floor (1 - crps/crps_naive)."
          },
          "last_updated": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "Most recent resolved origin contributing to this cell."
          }
        }
      }
    },
    "cumulative": {
      "type": "array",
      "description": "Cumulative-mean-CRPS-over-time series, one per (method, model, horizon), for the overview trend lines.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "model", "horizon", "series"],
        "properties": {
          "method": { "type": "string" },
          "model": { "type": ["string", "null"] },
          "horizon": { "type": "integer", "minimum": 1 },
          "series": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["origin_date", "cumulative_mean_crps", "n"],
              "properties": {
                "origin_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
                "cumulative_mean_crps": { "type": "number", "minimum": 0 },
                "n": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
