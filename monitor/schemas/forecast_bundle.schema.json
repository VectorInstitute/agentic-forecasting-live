{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VectorInstitute/agentic-forecasting-live/main/monitor/schemas/forecast_bundle.schema.json",
  "title": "Per-origin forecast bundle",
  "description": "Everything the single-forecast drill-down needs for one origin: every method/model prediction record, the resolution records that have landed, and a realized-value summary. Composed from the prediction and resolution record schemas.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "generated_at", "origin_date", "predictions", "resolutions", "realized"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_by": {
      "type": "string",
      "enum": ["mock", "harness"]
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "origin_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "predictions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://raw.githubusercontent.com/VectorInstitute/agentic-forecasting-live/main/monitor/schemas/prediction.schema.json"
      }
    },
    "resolutions": {
      "type": "array",
      "items": {
        "$ref": "https://raw.githubusercontent.com/VectorInstitute/agentic-forecasting-live/main/monitor/schemas/resolution.schema.json"
      }
    },
    "realized": {
      "type": "array",
      "description": "Realized cumulative log return per resolved horizon (the market outcome, shared across methods).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["horizon", "forecast_date", "realized_value"],
        "properties": {
          "horizon": { "type": "integer", "minimum": 1 },
          "forecast_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "realized_value": { "type": "number" }
        }
      }
    }
  }
}
